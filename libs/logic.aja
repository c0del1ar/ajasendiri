fuc allTrue(items: list[bool]) -> bool:
    for item in items:
        if not item:
            return false
    return true

fuc anyTrue(items: list[bool]) -> bool:
    for item in items:
        if item:
            return true
    return false

fuc noneTrue(items: list[bool]) -> bool:
    return not anyTrue(items)

export (
    allTrue,
    anyTrue,
    noneTrue
)
